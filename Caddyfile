{
    auto_https off
}

{$ROOT_DOMAIN} {
    redir https://{$WWW_DOMAIN}{uri} 300
}

http://{$WWW_DOMAIN} {
    @media path /media/*
    handle @media {
        root * /srv
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle_path /api/* {
        reverse_proxy backend:8000
    }

    reverse_proxy frontend:80
}
