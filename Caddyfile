{
    auto_https off
}

jasonhavill.com {
    redir https://www.jasonhavill.com{uri} 300
}

http://www.jasonhavill.com {
    @media path /media/*
    handle @media {
        root * /srv
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle_path /api/* {
        reverse_proxy backend:8000
    }

    reverse_proxy frontend:80
}
