POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=jhavill
ADMIN_API_TOKEN=replace_with_a_long_random_token
ADMIN_SESSION_COOKIE_SECURE=true
CLOUDFLARE_TUNNEL_TOKEN=your_token_here
CLOUDFLARE_TUNNEL_ID=your_tunnel_id_here
ROOT_DOMAIN=example.com
WWW_DOMAIN=www.example.com
CORS_ALLOW_ORIGINS=https://www.example.com,http://localhost,http://localhost:4200
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_IP_HEADER=CF-Connecting-IP
